{
  "name": "wild-semantic-layer",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm test:e2e && pnpm --filter @madebywild/semantic-layer-demo showcase",
    "demo": "pnpm --filter @madebywild/semantic-layer build && pnpm --filter @madebywild/semantic-layer-demo showcase",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint --error-on-warnings .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --project=unit --project=integration",
    "test:e2e": "vitest run --project=e2e",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@madebywild/agent-harness-framework": "^1.10.1",
    "@orama/orama": "3.1.18",
    "@types/node": "25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "testcontainers": "11.14.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6",
    "yaml": "2.9.0"
  },
  "optionalDependencies": {
    "fastembed": "2.1.0"
  }
}
