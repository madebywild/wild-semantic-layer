{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "*.json",
      "*.ts",
      "apps/**/*.js",
      "packages/**/*.ts",
      "tests/**/*.ts",
      ".harness/src/**/*.json",
      ".harness/src/**/*.ts",
      "!coverage",
      "!dist",
      "!node_modules",
      "!.tmp"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
